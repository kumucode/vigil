# ─────────────────────────────────────────────────────────────────────────────
#  Vigil — environment configuration
#  Copy this file to .env and fill in the values you need.
#  All variables are optional unless noted.
# ─────────────────────────────────────────────────────────────────────────────

# ── Network ───────────────────────────────────────────────────────────────────
PORT=3000                        # Host port the web UI is served on

# ── Security (important when exposing to the internet) ───────────────────────
# Set SECURE_COOKIES=true when running behind a TLS reverse proxy
# (Nginx Proxy Manager, Traefik, Caddy, etc.).
# Leaving it false is fine for LAN-only deployments.
SECURE_COOKIES=false
SESSION_LIFETIME_HOURS=12  # absolute session lifetime in hours (default 12) — session expires 12h after login, not after inactivity

# Restrict CORS to your specific domain when exposed over the internet.
# Use * (the default) for LAN-only or during development.
# ALLOWED_ORIGIN=https://track.yourdomain.com

# ── Scheduler ─────────────────────────────────────────────────────────────────
# Sets the initial check interval on first run. After that, change it in the
# Vigil UI (Settings → General) — UI changes persist across restarts.
CHECK_INTERVAL_HOURS=6           # How often to auto-check for updates

# ── Telegram notifications (optional) ────────────────────────────────────────
# Get a bot token from @BotFather, then your chat ID from @userinfobot.
# These values are seeded into the database on first run. After saving in the
# Vigil UI, the database value is used — changes here have no further effect.
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ── Webhook notifications (optional) ─────────────────────────────────────────
# Works with ntfy, Gotify, Discord (webhook URL), Slack (incoming webhook), etc.
# WEBHOOK_URL=https://ntfy.sh/your-topic

# ── Registry API tokens (optional — raises rate limits) ──────────────────────
# Without tokens, anonymous rate limits apply (Docker Hub: 100/6h per IP).
# GitHub:  Settings → Developer settings → Personal access tokens (read:packages)
# GitLab:  User Settings → Access Tokens (read_registry)
# Gitea:   User Settings → Applications → Generate Token
GITHUB_TOKEN=
GITLAB_TOKEN=
GITEA_TOKEN=    # Also used for Forgejo and Codeberg
